[
  {
    "start": 6.064,
    "end": 8.058,
    "text": "sweet heart,"
  },
  {
    "start": 8.058,
    "end": 9.494,
    "text": "sweet part,"
  },
  {
    "start": 9.494,
    "end": 11.169,
    "text": "lend me your wind,"
  },
  {
    "start": 11.169,
    "end": 21.83,
    "text": "lend me you chart."
  },
  {
    "start": 22.181,
    "end": 23.696,
    "text": "I've got six breaths,"
  },
  {
    "start": 23.696,
    "end": 25.611,
    "text": "still full of steam."
  },
  {
    "start": 25.611,
    "end": 27.686,
    "text": "I've been far away,"
  },
  {
    "start": 27.686,
    "end": 28.882,
    "text": "long since seen."
  },
  {
    "start": 28.882,
    "end": 30.878,
    "text": "I'm full of anticipation,"
  },
  {
    "start": 30.878,
    "end": 32.552,
    "text": "it's a strange odd sensation."
  },
  {
    "start": 32.552,
    "end": 35.904,
    "text": "mean maybe a wee bit mad,"
  },
  {
    "start": 35.904,
    "end": 38.457,
    "text": "still at odds with the world me lad."
  },
  {
    "start": 38.457,
    "end": 41.808,
    "text": "aye, who's to say this ain't okay."
  },
  {
    "start": 41.808,
    "end": 43.484,
    "text": "it ain't goodbye,"
  },
  {
    "start": 43.484,
    "end": 45.798,
    "text": "just another horizon,"
  },
  {
    "start": 45.798,
    "end": 51.192,
    "text": "under a different sky."
  },
  {
    "start": 51.542,
    "end": 54.972,
    "text": "sweet little heart I don't carry the same,"
  },
  {
    "start": 54.972,
    "end": 57.366,
    "text": "sweetheart didn't bury your name."
  },
  {
    "start": 57.366,
    "end": 58.005,
    "text": "sour old sot,"
  },
  {
    "start": 58.005,
    "end": 61.116,
    "text": "something's strange is afoot."
  },
  {
    "start": 61.116,
    "end": 62.951,
    "text": "some thing settle and clear,"
  },
  {
    "start": 62.951,
    "end": 64.628,
    "text": "right here,"
  },
  {
    "start": 64.628,
    "end": 71.218,
    "text": "right here."
  },
  {
    "start": 71.569,
    "end": 73.245,
    "text": "think I tossed and turned,"
  },
  {
    "start": 73.245,
    "end": 75.239,
    "text": "me head til I learned."
  },
  {
    "start": 75.239,
    "end": 78.59,
    "text": "learned I'm ain't gonna find you there."
  },
  {
    "start": 78.59,
    "end": 80.903,
    "text": "there around the corner of my eye,"
  },
  {
    "start": 80.903,
    "end": 82.899,
    "text": "stood all small and shy."
  },
  {
    "start": 82.899,
    "end": 84.176,
    "text": "why, why."
  },
  {
    "start": 84.176,
    "end": 85.611,
    "text": "tell me why."
  },
  {
    "start": 85.611,
    "end": 86.888,
    "text": "tell me friend,"
  },
  {
    "start": 86.888,
    "end": 88.245,
    "text": "can we not pretend."
  },
  {
    "start": 88.245,
    "end": 90.319,
    "text": "can we fend,"
  },
  {
    "start": 90.319,
    "end": 92.793,
    "text": "not only for our little self."
  },
  {
    "start": 92.793,
    "end": 95.346,
    "text": "lay your sorrows not on this shelf."
  },
  {
    "start": 95.346,
    "end": 96.781,
    "text": "let's see,"
  },
  {
    "start": 96.781,
    "end": 97.819,
    "text": "what we."
  },
  {
    "start": 97.819,
    "end": 100.739,
    "text": "can do together."
  },
  {
    "start": 101.09,
    "end": 104.361,
    "text": "sweet little heart I don't carry in kind,"
  },
  {
    "start": 104.361,
    "end": 107.951,
    "text": "sweetheart never I'll mind."
  },
  {
    "start": 107.951,
    "end": 109.149,
    "text": "sour old sot,"
  },
  {
    "start": 109.149,
    "end": 110.665,
    "text": "something's strange is afoot."
  },
  {
    "start": 110.665,
    "end": 112.5,
    "text": "some thing settle and clear,"
  },
  {
    "start": 112.5,
    "end": 114.176,
    "text": "right there,"
  },
  {
    "start": 114.176,
    "end": 142.468,
    "text": "right there."
  },
  {
    "start": 142.818,
    "end": 144.254,
    "text": "tell me then,"
  },
  {
    "start": 144.254,
    "end": 146.409,
    "text": "little lovely light."
  },
  {
    "start": 146.409,
    "end": 151.037,
    "text": "do you prefer I say goodnight."
  },
  {
    "start": 151.037,
    "end": 153.111,
    "text": "tell me cariad,"
  },
  {
    "start": 153.111,
    "end": 155.265,
    "text": "my sweet heart."
  },
  {
    "start": 155.265,
    "end": 159.734,
    "text": "how could I start."
  },
  {
    "start": 159.734,
    "end": 161.728,
    "text": "over again."
  }
]

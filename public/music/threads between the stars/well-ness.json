[
  {
    "start": 23.297,
    "end": 26.089,
    "text": "Platform four, a pneumatic roar,"
  },
  {
    "start": 26.089,
    "end": 28.722,
    "text": "Think I must have come this way before."
  },
  {
    "start": 28.722,
    "end": 31.754,
    "text": "little gold start sticker, in the sunlight flickers,"
  },
  {
    "start": 31.754,
    "end": 35.426,
    "text": "hardly able to stand, just by this hand."
  },
  {
    "start": 35.426,
    "end": 38.298,
    "text": "sundry voice in a concrete hall,"
  },
  {
    "start": 38.298,
    "end": 41.09,
    "text": "lean the head back against the cold wall."
  },
  {
    "start": 41.09,
    "end": 44.121,
    "text": "Too much history, too much to know,"
  },
  {
    "start": 44.121,
    "end": 47.521,
    "text": "nearly here, almost time to go."
  },
  {
    "start": 47.871,
    "end": 51.831,
    "text": "stingly sundry breath"
  },
  {
    "start": 52.18,
    "end": 53.457,
    "text": "now ticking the clock"
  },
  {
    "start": 53.457,
    "end": 58.851,
    "text": "of sudden death."
  },
  {
    "start": 59.201,
    "end": 60.558,
    "text": "change of pace,"
  },
  {
    "start": 60.558,
    "end": 62.073,
    "text": "motion blurr"
  },
  {
    "start": 62.073,
    "end": 63.59,
    "text": "Loud the voices,"
  },
  {
    "start": 63.59,
    "end": 64.947,
    "text": "as they stir."
  },
  {
    "start": 64.947,
    "end": 65.504,
    "text": "no,"
  },
  {
    "start": 65.504,
    "end": 66.621,
    "text": "its nothing,"
  },
  {
    "start": 66.621,
    "end": 67.739,
    "text": "close the door."
  },
  {
    "start": 67.739,
    "end": 69.415,
    "text": "don't like this much at all,"
  },
  {
    "start": 69.415,
    "end": 95.155,
    "text": "not any more."
  },
  {
    "start": 95.504,
    "end": 98.855,
    "text": "Down in this trench,"
  },
  {
    "start": 98.855,
    "end": 101.489,
    "text": "all noise is quenched."
  },
  {
    "start": 101.489,
    "end": 102.605,
    "text": "Happy, happy"
  },
  {
    "start": 102.605,
    "end": 104.441,
    "text": "with the volume today."
  },
  {
    "start": 104.441,
    "end": 106.834,
    "text": "Aye, come out to play."
  },
  {
    "start": 106.834,
    "end": 108.59,
    "text": "shouting out names,"
  },
  {
    "start": 108.59,
    "end": 109.787,
    "text": "playing games."
  },
  {
    "start": 109.787,
    "end": 111.302,
    "text": "The woman is crying,"
  },
  {
    "start": 111.302,
    "end": 112.34,
    "text": "no, now I am lying."
  },
  {
    "start": 112.34,
    "end": 112.899,
    "text": "She just, catches her breath."
  },
  {
    "start": 112.899,
    "end": 118.323,
    "text": "mumbles a little something about"
  },
  {
    "start": 118.323,
    "end": 120.558,
    "text": "life and death."
  },
  {
    "start": 120.558,
    "end": 122.552,
    "text": "Like everyone else here,"
  },
  {
    "start": 122.552,
    "end": 124.548,
    "text": "she's just trying."
  },
  {
    "start": 124.548,
    "end": 127.34,
    "text": "prying eyes,"
  },
  {
    "start": 127.34,
    "end": 128.537,
    "text": "a guise,"
  },
  {
    "start": 128.537,
    "end": 134.33,
    "text": "just to see us in surprise."
  },
  {
    "start": 134.681,
    "end": 136.645,
    "text": "oh no"
  },
  {
    "start": 136.995,
    "end": 138.799,
    "text": "no not this again"
  },
  {
    "start": 139.149,
    "end": 139.169,
    "text": "(Sundry... sundry...)"
  },
  {
    "start": 139.149,
    "end": 140.824,
    "text": "holy, hevenly,"
  },
  {
    "start": 140.824,
    "end": 142.181,
    "text": "non-being."
  },
  {
    "start": 142.181,
    "end": 143.697,
    "text": "fragile all-seeing"
  },
  {
    "start": 143.697,
    "end": 149.201,
    "text": "god father of well-being."
  },
  {
    "start": 149.201,
    "end": 150.558,
    "text": "give me another except,"
  },
  {
    "start": 150.558,
    "end": 151.754,
    "text": "a quote from the book,"
  },
  {
    "start": 151.754,
    "end": 153.83,
    "text": "let me have a quick look."
  },
  {
    "start": 153.83,
    "end": 158.377,
    "text": "must have mistook,"
  },
  {
    "start": 158.377,
    "end": 160.293,
    "text": "this,"
  },
  {
    "start": 160.293,
    "end": 160.661,
    "text": "for self-help."
  }
]
